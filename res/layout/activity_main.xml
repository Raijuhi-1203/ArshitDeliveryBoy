<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:gravity="center"
    android:background="@color/white"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#0300C8B7"
        app:cardMaxElevation="12dp"
        app:cardPreventCornerOverlap="true"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="0dp"
            android:layout_marginTop="0dp"
            android:layout_marginRight="0dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="0dp">

            <ImageView
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:src="@drawable/easylifelogo"/>

<!--            <TextView-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:textColor="@color/app_org"-->
<!--                android:textStyle="bold"-->
<!--                android:textSize="19dp"-->
<!--                android:textAlignment="center"-->
<!--                android:fontFamily="@font/custom_font"-->
<!--                android:layout_marginBottom="25dp"-->
<!--                android:text="Easy Life Delivery-Boy app" />-->

            <EditText
                android:id="@+id/mob"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_margin="8dp"
                android:background="@drawable/editext_box"
                android:drawableStart="@drawable/baseline_call_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/app_org"
                android:fontFamily="@font/custom_font"
                android:hint="Enter Mobile No."
                android:inputType="number"
                android:maxLength="12"
                android:padding="5dp"
                android:textColor="@color/app_org"
                android:textColorHint="@color/app_org"
                android:textSize="16dp" />

            <EditText
                android:id="@+id/pass"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_margin="8dp"
                android:background="@drawable/editext_box"
                android:drawableStart="@drawable/baseline_lock_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/app_org"
                android:fontFamily="@font/custom_font"
                android:hint="Enter Password"
                android:inputType="textPassword"
                android:padding="5dp"
                android:textColor="@color/app_org"
                android:textColorHint="@color/app_org"
                android:textSize="16dp" />

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp"
                android:background="@drawable/btn_org"
                android:fontFamily="@font/custom_font"
                android:text="LOGIN"
                android:textColor="@color/yellow"
                android:textSize="16dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>