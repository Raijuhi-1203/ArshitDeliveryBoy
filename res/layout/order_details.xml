<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".Fragment.ShopFragment"
        android:orientation="vertical">

        <include layout="@layout/header2"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.core.widget.NestedScrollView
                    android:layout_marginBottom="70dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:orientation="vertical">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_margin="5dp"
                            android:padding="5dp"
                            android:background="@drawable/planbox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/orderid"
                                android:text="Order ID : ODR202121"
                                android:textSize="16dp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/sorderid"
                                android:text="SubOrder ID : ODRS8191"
                                android:textSize="14dp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/status"
                                android:text="Delivered"
                                android:textSize="14dp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Shipping Details"
                            android:textSize="16dp"
                            android:textStyle="bold"
                            android:layout_margin="5dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/custom_font"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_margin="5dp"
                            android:padding="5dp"
                            android:background="@drawable/planbox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/cnm"
                                android:text="Codesgesture Technology"
                                android:textSize="16dp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/add"
                                android:text="Near Shiv mandir, Betiahata, Gorakhpur,UP-273010"
                                android:textSize="14dp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/mob"
                                android:text="9628092950"
                                android:textSize="14dp"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:fontFamily="@font/custom_font"/>


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:id="@+id/mail"
                                android:text="codesgesture@gmail.com"
                                android:textSize="14dp"
                                android:textStyle="bold"
                                android:textColor="@color/green"
                                android:fontFamily="@font/custom_font"/>

                        </LinearLayout>

                        <Button
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="35dp"
                            android:id="@+id/btcancel"
                            android:text="Cancel"
                            android:layout_weight="1"
                            android:layout_margin="5dp"
                            android:background="@drawable/btnblue"
                            android:textColor="@color/white"
                            android:fontFamily="@font/custom_font"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:weightSum="2">

                            <Button
                                android:visibility="gone"
                                android:layout_width="match_parent"
                                android:layout_height="35dp"
                                android:id="@+id/btallcncl"
                                android:text="Cancel All items"
                                android:layout_weight="1"
                                android:layout_margin="5dp"
                                android:background="@drawable/btnblue"
                                android:textColor="@color/white"
                                android:fontFamily="@font/custom_font"/>

                            <Button
                                android:layout_width="match_parent"
                                android:layout_height="35dp"
                                android:id="@+id/istatus"
                                android:text="Delivered"
                                android:layout_weight="1"
                                android:layout_margin="5dp"
                                android:background="@drawable/btn_green"
                                android:textColor="@color/white"
                                android:fontFamily="@font/custom_font"/>

                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Total Price Details"
                            android:textSize="16dp"
                            android:textStyle="bold"
                            android:layout_margin="5dp"
                            android:textColor="@color/black"
                            android:fontFamily="@font/custom_font"/>

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_margin="5dp"
                            android:padding="5dp"
                            android:background="@drawable/planbox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <LinearLayout
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:weightSum="2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Payment Mode"
                                    android:textSize="16dp"
                                    android:textStyle="bold"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/pmode"
                                    android:text="Cash on Delivery"
                                    android:textSize="16dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                            </LinearLayout>

                            <LinearLayout
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:weightSum="2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Total MRP"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/tmrp"
                                    android:text="Rs. 0.00"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>
                            </LinearLayout>

                            <LinearLayout
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:weightSum="2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Shipping Charge"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/scharge"
                                    android:text="Rs. 0.00"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>
                            </LinearLayout>

                            <LinearLayout
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:weightSum="2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Discount"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/dis"
                                    android:text="Rs. 0.00"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>
                            </LinearLayout>

                            <LinearLayout
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:weightSum="2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Coupon Discount"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/cdis"
                                    android:text="Rs. 0.00"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                            </LinearLayout>

                            <LinearLayout
                                android:orientation="horizontal"
                                android:padding="5dp"
                                android:weightSum="2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Grand Total"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/black"
                                    android:fontFamily="@font/custom_font"/>

                                <TextView
                                    android:textAlignment="center"
                                    android:layout_weight="1"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/gtotal"
                                    android:text="Rs. 0.00"
                                    android:textSize="14dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/green"
                                    android:fontFamily="@font/custom_font"/>

                            </LinearLayout>

                            <Button
                                android:layout_width="match_parent"
                                android:layout_height="35dp"
                                android:id="@+id/btdelivered"
                                android:text="Delivered"
                                android:layout_weight="1"
                                android:layout_margin="5dp"
                                android:background="@drawable/btnblue"
                                android:textColor="@color/app_org"
                                android:fontFamily="@font/custom_font"/>


                        </LinearLayout>
                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>
            </RelativeLayout>
        </RelativeLayout>
    </LinearLayout>
</LinearLayout>