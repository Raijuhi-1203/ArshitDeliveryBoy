<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />


    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_easylogo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_easylogo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ArshitDeliveryBoy"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name="codesgesture.app.arshitdeliveryboy.Dashboard" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.Profile" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.MenuPage" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageDeveloper" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageContact" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageAbout" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageFAQ" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PagePrivacy" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageTerm" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageRefund" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PagePendingOrder" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.PageOrderDetails" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.MyDelivery" />
        <activity android:name="codesgesture.app.arshitdeliveryboy.CollectionReport" />
    </application>

</manifest>